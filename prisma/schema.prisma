generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Inward {
  id           String       @id @default(uuid())
  from         String
  remarks      String?
  documentData String?  
  date         DateTime     @default(now())
  items        InwardItem[]
}

model InwardItem {
  id          String   @id @default(uuid())
  inwardId    String
  inward      Inward   @relation(fields: [inwardId], references: [id])
  modelNo     String
  productType String
  slNo        String?
  qty         Int
}

model Outward {
  id           String        @id @default(uuid())
  customerName String
  contactNo    String
  address      String
  projectName  String?
  from         String
  remarks      String?
  date         DateTime      @default(now())
  items        OutwardItem[]
}

model OutwardItem {
  id          String   @id @default(uuid())
  outwardId   String
  outward     Outward  @relation(fields: [outwardId], references: [id])
  modelNo     String
  productType String
  slNo        String?
  qty         Int
  unitValue   Float    @default(0)
}
